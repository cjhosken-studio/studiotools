{
  "name": "studiotools",
  "version": "1.0.0",
  "type": "module",
  "description": "This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently -k -n \"npm run backend\" \"npm run frontend\" \"npm run electron\"",
    "backend": "cd backend && python -m uvicorn main:app --reload",
    "frontend": "vite",
    "electron": "wait-on tcp:8000 && wait-on http://localhost:3000 && electron .",
    "build": "vite build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ps-node": "^0.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "kill-port": "^2.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "cjhosken.studio.studiotools",
    "productName": "studiotools",
    "icon": "public/icon.png",
    "asar": false,
    "files": [
      "public/**/*",
      "backend/**/*",
      "dist/**/*",
      "electron/**/*",
      "!.venv"
    ],
    "extraResources": [
      {
        "from": ".venv",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "category": "VFX"
    }
  }
}
